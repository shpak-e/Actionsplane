# Copy to .env for local dev (.env is gitignored). Prod uses real secrets via KMS/sealed-secret.
ACTIONSPLANE_DATABASE_URL=postgresql+asyncpg://actionsplane:actionsplane@localhost:5432/actionsplane
# Redis requires a password (review 4, H-1) — embed it in the URL: redis://:<password>@host:6379/0
# The dev compose stack starts Redis with `--requirepass` defaulting to "actionsplane" (override
# via REDIS_PASSWORD). Alternatively set ACTIONSPLANE_REDIS_PASSWORD and keep the URL bare; the app
# injects it into the URL at startup (see Settings.effective_redis_url).
ACTIONSPLANE_REDIS_URL=redis://:actionsplane@localhost:6379/0
# Used by docker compose (the redis-server --requirepass value) — keep in sync with the URL above.
REDIS_PASSWORD=actionsplane

# GitHub App — create at https://github.com/settings/apps
ACTIONSPLANE_GITHUB_APP_ID=
ACTIONSPLANE_GITHUB_APP_PRIVATE_KEY_PATH=./actionsplane.private-key.pem
ACTIONSPLANE_GITHUB_WEBHOOK_SECRET=

# Bulk edits write to repos — opt-in, off by default.
ACTIONSPLANE_BULK_EDITS_ENABLED=false

# Code Scanning (SARIF) upload — opt-in, off by default. When true, ActionsPlane requests the
# `security_events: write` scope and pushes findings to the GitHub Security tab after each audit.
ACTIONSPLANE_SECURITY_EVENTS_ENABLED=false

# OpenTelemetry tracing — off by default (all tracing hooks become no-ops). When true, spans are
# exported over OTLP and stitched into one trace across ingest → worker → audit → SARIF.
ACTIONSPLANE_OTEL_ENABLED=false
ACTIONSPLANE_OTEL_ENDPOINT=  # e.g. http://otel-collector:4317 (else honours OTEL_EXPORTER_OTLP_*)

# Offline mode (no GitHub App): a comma-separated list of public repos (owner/repo or URLs).
# When set, the system pulls their workflows + runs on startup and on a manual Sync — read-only,
# no webhooks, no live updates. Optionally set ACTIONSPLANE_GITHUB_TOKEN (a plain PAT) for a
# higher rate limit or private-repo access. Leave empty to use GitHub App mode.
ACTIONSPLANE_OFFLINE_REPOS=
ACTIONSPLANE_GITHUB_TOKEN=
